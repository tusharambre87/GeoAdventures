{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "backfill:intelligence": "tsx src/planner/backfillIntelligence.ts",
    "backfill:logistics": "tsx src/planner/backfillLogistics.ts",
    "backfill:missions": "tsx src/planner/backfillMissions.ts"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.1",
    "@sendgrid/mail": "^8.1.6",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.4",
    "memoizee": "^0.4.17",
    "multer": "^2.1.1",
    "openai": "^6.39.0",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "stripe": "^22.1.1",
    "stripe-replit-sync": "^1.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod-validation-error": "^5.0.0"
